{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npm run type-check && npm run lint",
            "timeout": 60,
            "statusMessage": "Running type-check and lint..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npm run format && npm run build",
            "timeout": 180,
            "statusMessage": "Running format and build..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm run type-check *)",
      "Bash(npm run check *)",
      "Bash(npm run lint *)",
      "Bash(npm run format *)",
      "Bash(npm run build *)",
      "Bash(npx tsc --noEmit *)"
    ]
  }
}
