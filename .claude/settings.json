{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npm run type-check && npm run lint && npm run format && npm run build",
            "statusMessage": "Running type-check, lint, format, and build..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm run type-check *)",
      "Bash(npm run check *)",
      "Bash(npm run lint *)",
      "Bash(npm run format *)",
      "Bash(npm run build *)"
    ]
  }
}
