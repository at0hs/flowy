{
  "cSpell.ignorePaths": [
    "package-lock.json",
    "node_modules",
    "vscode-extension",
    ".git/{info,lfs,logs,refs,objects}/**",
    ".git/{index,*refs,*HEAD}",
    ".vscode",
    ".vscode-insiders",
    ".gitignore"
  ],
  "editor.wordWrap": "on",
  "cSpell.words": ["fkey", "flowy", "ilike", "plpgsql", "Redmine", "shadcn", "SUPABASE"],
  "files.eol": "\n"
}
