{
	"[sql]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"cSpell.ignorePaths": [
		"package*.json",
		"node_modules",
		"vscode-extension",
		".git/{info,lfs,logs,refs,objects}/**",
		".git/{index,*refs,*HEAD}",
		".vscode",
		".vscode-insiders",
		".gitignore"
	],
	"cSpell.words": [
		"fkey",
		"flowy",
		"ilike",
		"plpgsql",
		"Redmine",
		"shadcn",
		"SUPABASE"
	],
	"editor.wordWrap": "on",
	"files.eol": "\n",
	"editor.detectIndentation": false,
	"sqltools.connections": [
		{
			"ssh": "Disabled",
			"previewLimit": 50,
			"server": "127.0.0.1",
			"port": 54322,
			"driver": "PostgreSQL",
			"name": "supabase local",
			"database": "postgres",
			"username": "postgres",
			"password": "postgres"
		}
	],
}
