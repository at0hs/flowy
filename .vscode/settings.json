{
	"[sql]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"cSpell.ignorePaths": [
		"package*.json",
		"node_modules",
		"vscode-extension",
		".git/{info,lfs,logs,refs,objects}/**",
		".git/{index,*refs,*HEAD}",
		".vscode",
		".vscode-insiders",
		".gitignore"
	],
	"cSpell.words": [
		"fkey",
		"flowy",
		"ilike",
		"plpgsql",
		"Redmine",
		"shadcn",
		"SUPABASE"
	],
	"editor.wordWrap": "on",
	"files.eol": "\n",
}
