{
	"[sql]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
		"editor.tabSize": 2,
		"editor.insertSpaces": true
	},
	"cSpell.ignorePaths": [
		"package*.json",
		"node_modules",
		"vscode-extension",
		".git/{info,lfs,logs,refs,objects}/**",
		".git/{index,*refs,*HEAD}",
		".vscode",
		".vscode-insiders",
		".gitignore",
		"*.toml"
	],
	"cSpell.words": [
		"fkey",
		"flowy",
		"ilike",
		"moddatetime",
		"nums",
		"plpgsql",
		"Redmine",
		"Setof",
		"shadcn",
		"Subticket",
		"subtickets",
		"SUPABASE",
		"timestamptz"
	],
	"editor.wordWrap": "on",
	"files.eol": "\n",
	"editor.detectIndentation": false,
	"sqltools.connections": [
		{
			"ssh": "Disabled",
			"previewLimit": 50,
			"server": "127.0.0.1",
			"port": 54322,
			"driver": "PostgreSQL",
			"name": "supabase local",
			"database": "postgres",
			"username": "postgres",
			"password": "postgres"
		}
	],
}
