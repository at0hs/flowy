{
  "name": "flowy",
  "version": "0.5.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3111",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run type-check && npm run lint && npm run format:check",
    "validate": "npm run check && npm run build",
    "gen:types": "supabase gen types typescript --local > types/database.types.ts",
    "sb:start": "supabase start",
    "sb:stop": "supabase stop",
    "sb:status": "supabase status",
    "sb:reset": "supabase db reset",
    "sb:push": "supabase db push",
    "sb:lint": "supabase db lint",
    "sb:migration": "npm run sb:reset && npm run sb:lint && npm run gen:types",
    "sb:func-serve": "supabase functions serve",
    "email:dev": "email dev --dir emails",
    "build:emails": "tsx scripts/build-emails.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.52",
